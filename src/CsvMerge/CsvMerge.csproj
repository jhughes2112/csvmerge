<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>csvmerge</AssemblyName>
    <RootNamespace>CsvMerge</RootNamespace>
    <InvariantGlobalization>true</InvariantGlobalization>
    <PackAsTool>true</PackAsTool>
    <ToolCommandName>csvmerge</ToolCommandName>
    <Version>0.1.0</Version>
    <Description>Git-native three-way merge driver for CSV files.</Description>
    <ApplicationIcon>..\..\csvmerge.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="CsvHelper" Version="33.0.1" />
  </ItemGroup>

</Project>
